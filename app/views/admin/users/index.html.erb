<% content_for :title, "Users" %>

<h1>Users</h1>

<table class="admin-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td>
          <%= form_with model: user, url: admin_user_path(user), method: :patch, class: "admin-inline-form" do |f| %>
            <%= f.select :role, User.roles.keys, {}, onchange: "this.form.requestSubmit()" %>
          <% end %>
        </td>
        <td>
          <% unless user == current_user %>
            <%= button_to "Delete", admin_user_path(user), method: :delete, class: "btn btn--danger btn--sm", data: { turbo_confirm: "Delete this user?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
