<% content_for :title, "Posts" %>

<div class="page-header">
  <h1>All Posts</h1>
  <%= link_to "Write a post", new_post_path, class: "btn btn--primary" %>
</div>

<%= turbo_frame_tag "posts" do %>
  <% if @posts.any? %>
    <div class="post-list">
      <% @posts.each do |post| %>
        <%= render "posts/post_card", post: post %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p>No posts yet. <%= link_to "Create your first post", new_post_path %>.</p>
    </div>
  <% end %>
<% end %>
