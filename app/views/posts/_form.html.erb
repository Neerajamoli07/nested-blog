<%= form_with model: post, class: "form", html: { multipart: true } do |form| %>
  <% if post.errors.any? %>
    <div class="form-errors" id="post_form_errors">
      <h3><%= pluralize(post.errors.count, "error") %> prevented this post from being saved:</h3>
      <ul>
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= form.label :title %>
    <%= form.text_field :title, placeholder: "Post title", required: true %>
  </div>

  <div class="form-field">
    <%= form.label :body %>
    <%= form.text_area :body, rows: 12, placeholder: "Write your post...", required: true %>
  </div>

  <div class="form-field">
    <%= form.label :cover_image, "Cover image" %>
    <%= form.file_field :cover_image, accept: "image/png,image/jpeg,image/webp" %>
    <% if post.cover_image.attached? %>
      <div class="form-preview">
        <%= image_tag post.cover_image.variant(resize_to_limit: [ 320, 160 ]) %>
      </div>
    <% end %>
  </div>

  <div class="form-field">
    <%= form.label :status %>
    <%= form.select :status, Post.statuses.keys.map { |s| [ s.humanize, s ] } %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn btn--primary" %>
    <%= link_to "Cancel", post.persisted? ? post : posts_path, class: "btn btn--ghost" %>
  </div>
<% end %>
