<% content_for :title, "Login" %>

<div class="auth-card">
  <h1>Sign in</h1>

  <%= form_with url: login_path, class: "form" do |form| %>
    <div class="form-field">
      <%= form.label :email %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="form-field">
      <%= form.label :password %>
      <%= form.password_field :password, required: true, autocomplete: "current-password" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Sign in", class: "btn btn--primary" %>
    </div>
  <% end %>

  <p class="auth-card__footer">
    Don't have an account? <%= link_to "Sign up", signup_path %>
  </p>
</div>
