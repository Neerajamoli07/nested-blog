<!DOCTYPE html>
<html>
  <head>
    <title>Admin · <%= content_for(:title) || "Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin-body">
    <aside class="admin-sidebar">
      <h2>Admin</h2>
      <nav>
        <%= link_to "Dashboard", admin_root_path, class: "admin-nav__link" %>
        <%= link_to "Users", admin_users_path, class: "admin-nav__link" %>
        <%= link_to "Posts", admin_posts_path, class: "admin-nav__link" %>
        <%= link_to "← Back to site", root_path, class: "admin-nav__link" %>
      </nav>
    </aside>
    <main class="admin-main">
      <div id="flash"><%= render "shared/flash" %></div>
      <%= yield %>
    </main>
  </body>
</html>
