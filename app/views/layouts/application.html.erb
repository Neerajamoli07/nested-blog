<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Blog App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if logged_in? %>
      <%= turbo_stream_from current_user, :notifications %>
    <% end %>

    <header class="site-header">
      <div class="container site-header__inner">
        <%= link_to root_path, class: "site-logo" do %>
          <span class="site-logo__mark">◆</span>
          <span class="site-logo__text">Blog App</span>
        <% end %>

        <%= form_with url: search_path, method: :get, class: "search-form", data: { turbo_frame: "_top" } do %>
          <%= text_field_tag :q, params[:q], placeholder: "Search posts...", class: "search-form__input", aria: { label: "Search" } %>
        <% end %>

        <nav class="site-nav">
          <% if logged_in? %>
            <%= link_to notifications_path, class: "site-nav__notifications" do %>
              <span>Notifications</span>
              <span id="notification_badge">
                <%= render "notifications/badge", count: unread_notifications_count %>
              </span>
            <% end %>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_root_path, class: "site-nav__link" %>
            <% end %>
            <%= link_to "New Post", new_post_path, class: "btn btn--primary" %>
            <div class="site-nav__user">
              <%= user_avatar(current_user) %>
              <span><%= current_user.name %></span>
              <%= button_to "Logout", logout_path, method: :delete, class: "btn btn--ghost btn--sm" %>
            </div>
          <% else %>
            <%= link_to "Login", login_path, class: "site-nav__link" %>
            <%= link_to "Sign up", signup_path, class: "btn btn--primary" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="container main-content">
      <div id="flash">
        <%= render "shared/flash" %>
      </div>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Real-time blog · Rails 8 · Hotwire · Action Cable · Active Storage</p>
      </div>
    </footer>
  </body>
</html>
